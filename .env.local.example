NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required for app login/session protection. Use 32+ random characters.
APP_SESSION_SECRET=replace-with-a-long-random-secret

# First admin login. After the admin user exists, reset/remove this in production.
APP_BOOTSTRAP_ADMIN_EMAIL=kevin@vidalcoaching.com
APP_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-temporary-password

# Required for scheduled cron endpoints. Use the same value in Vercel/GitHub callers.
CRON_SECRET=replace-with-a-long-random-cron-secret
